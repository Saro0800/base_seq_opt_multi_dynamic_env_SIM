<launch>
  <node name="image_bridge_node" pkg="image_bridge" type="image_bridge_node.py" output="screen">
    <param name="mqtt_host" value="192.168.0.106" />
    <param name="mqtt_port"  value="1883" />
    <param name="mqtt_topic_frame" value="image_bridge/frame" />
    <param name="mqtt_topic_map" value="image_bridge/map" />
    <param name="mqtt_qos" value="0" />
    <param name="queue_size" value="5" />
    <param name="slop" value="0.1" />
    <param name="depth_topic" value="/locobot/camera/aligned_depth_to_color/image_raw" />
    <param name="color_topic" value="/locobot/camera/color/image_raw" />
    <param name="camera_info_topic" value="/locobot/camera/aligned_depth_to_color/camera_info" />
    <param name="map_topic" value="/locobot/octomap_server/projected_map" />
    <param name="map_frame" value="octomap_frame" />
  </node>
</launch>
