<launch>
  <arg name="node_namespace"  default="apriltag_reader_node" />
  <arg name="launch_prefix"   default=""/>

  <!-- Set parameters -->
  <rosparam command="load" file="$(find base_optimization)/config/settings.yaml" ns="$(arg node_namespace)" />
  <rosparam command="load" file="$(find base_optimization)/config/tags.yaml" ns="$(arg node_namespace)" />

  <node
    pkg="apriltag_ros"
    type="apriltag_ros_continuous_node"
    name="$(arg node_namespace)"
    clear_params="true"
    output="screen"
    launch-prefix="$(arg launch_prefix)" >
    <!-- Remap topics from those used in code to those on the ROS network -->
    <!-- <remap from="image_rect" to="/locobot/hand_camera/camera/color/image_raw" />
    <remap from="camera_info" to="/locobot/hand_camera/camera/color/camera_info" /> -->
    <remap from="image_rect" to="/locobot/hand_camera/color/image_raw" />
    <remap from="camera_info" to="/locobot/hand_camera/color/camera_info" />

    <param name="publish_tag_detections_image" type="bool" value="true" /> 
    <param name="remove_duplicates" value="false" />
  </node>
</launch>
