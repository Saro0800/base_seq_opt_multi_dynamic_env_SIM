<launch>

  <arg name="robot_model"                       default="locobot_wx250s"/>
  <arg name="robot_name"                        default="locobot"/>
  <arg name="use_lidar"                         default="true"/>
  <arg name="show_lidar"                        default="$(arg use_lidar)"/>
  <arg name="external_urdf_loc"                 default=""/>
  <arg name="use_rviz"                          default="false"/>
  <arg name="base_type"                         default="$(optenv INTERBOTIX_XSLOCOBOT_BASE_TYPE create3)"/> <!-- 'kobuki', 'create3' -->
  <arg name="localization"                      default="true"/>
  <arg name="rtabmap_args"                      default=""/>
  <arg name="use_rtabmapviz"                    default="false"/>
  <arg name="rtabmapviz_args"                   default=""/>
  <arg name="database_path"                     default="~/base_pose_opt_multi_dynamic_env/src/maps/rtabmap_conf3.db"/>
  <arg name="camera_tilt_angle"                 default="0.2618"/>
  <arg name="launch_driver"                     default="true"/>

  <arg name="filters"                           default="pointcloud"/>
  <arg name="align_depth"                       default="true"/>
  <arg name="color_fps"                         default="30"/>
  <arg name="color_width"                       default="640"/>
  <arg name="color_height"                      default="480"/>
  <arg name="depth_fps"                         default="30"/>
  <arg name="depth_width"                       default="640"/>
  <arg name="depth_height"                      default="480"/>

  <!-- start the navigation stack -->
  <include file="$(find interbotix_xslocobot_nav)/launch/xslocobot_nav.launch" >
    <arg name="robot_model"                       value="$(arg robot_model)"/>
    <arg name="robot_name"                        value="$(arg robot_name)"/>
    <arg name="use_lidar"                         value="$(arg use_lidar)"/>
    <arg name="show_lidar"                        value="$(arg use_lidar)"/>
    <arg name="external_urdf_loc"                 value="$(arg external_urdf_loc)"/>
    <arg name="use_rviz"                          value="$(arg use_rviz)"/>
    <arg name="base_type"                         value="$(arg base_type)"/>
    <arg name="localization"                      value="$(arg localization)"/>
    <arg name="rtabmap_args"                      value="$(arg rtabmap_args)"/>
    <arg name="use_rtabmapviz"                    value="$(arg use_rtabmapviz)"/>
    <arg name="rtabmapviz_args"                   value="$(arg rtabmapviz_args)"/>
    <arg name="database_path"                     value="$(arg database_path)"/>
    <arg name="camera_tilt_angle"                 value="$(arg camera_tilt_angle)"/>
    <arg name="launch_driver"                     value="$(arg launch_driver)"/>
  </include>

  <!-- start the manipulation stack -->
  <include file="$(find interbotix_xslocobot_moveit)/launch/xslocobot_moveit.launch">
    <arg name="robot_model"                       value="$(arg robot_model)"/>
    <arg name="robot_name"                        value="$(arg robot_name)"/>
    <arg name="show_lidar"                        value="$(arg use_lidar)"/>
    <arg name="external_urdf_loc"                 value="$(arg external_urdf_loc)"/>
    <arg name="use_actual"                        value="true"/>
    <arg name="dof"                               value="6"/>
    <arg name="use_camera"                        value="true"/>
    <arg name="use_moveit_rviz"                   value="false"/>
    <arg name="launched_with_nav"                 value="true"/>
  </include>

  <!-- <node
    pkg="base_optimization"
    type="move_to_next_pose.py"
    respawn="false"
    name="move_to_next_pose"
    output="screen"
    ns="$(arg robot_name)">
  </node> -->

  <node
    pkg="base_optimization"
    type="image_giver.py"
    respawn="false"
    name="image_giver"
    output="screen"
    ns="$(arg robot_name)">
  </node>

  
  <arg name="filename"          default="'/home/locobot/base_pose_opt_multi_dynamic_env/src/maps/octomap_conf3.bt'" />
  <arg name="load_map_args"     default='"filename: $(arg filename)"'/> 
  <node pkg="rosservice" type="rosservice" name="load_octomap" args="call --wait /$(arg robot_name)/move_group/load_map $(arg load_map_args)" />

  <node pkg="rostopic" type="rostopic" name="init_shoulder_joint"
        args="pub -1 /locobot/commands/joint_single interbotix_xs_msgs/JointSingleCommand '{name: shoulder, cmd: -0.9}'"
        output="screen" />
  <node pkg="rostopic" type="rostopic" name="init_wrist_angle_joint"
        args="pub -1 /locobot/commands/joint_single interbotix_xs_msgs/JointSingleCommand '{name: wrist_angle, cmd: 0.0}'"
        output="screen" />
  <node pkg="rostopic" type="rostopic" name="init_tilt_angle_joint"
        args="pub -1 /locobot/commands/joint_single interbotix_xs_msgs/JointSingleCommand '{name: tilt, cmd: 0.2618}'"
        output="screen" />
  <node pkg="rostopic" type="rostopic" name="init_pan_angle_joint"
        args="pub -1 /locobot/commands/joint_single interbotix_xs_msgs/JointSingleCommand '{name: pan, cmd: 0.0}'"
        output="screen" />

  <include file="$(find realsense2_camera)/launch/rs_camera.launch" ns="$(arg robot_name)">
    <arg name="camera"                            value="hand_camera"/>
    <arg name="tf_prefix"		                      value="hand_camera"/>
    <arg name="filters"                           value="$(arg filters)"/>
    <arg name="align_depth"                       value="$(arg align_depth)"/>
    <arg name="color_fps"                         value="$(arg color_fps)"/>
    <arg name="color_width"                       value="$(arg color_width)"/>
    <arg name="color_height"                      value="$(arg color_height)"/>
    <arg name="depth_fps"                         value="$(arg depth_fps)"/>
    <arg name="depth_width"                       value="$(arg depth_width)"/>
    <arg name="depth_height"                      value="$(arg depth_height)"/>
    <arg name="serial_no"                         value="145422070718"/>
  </include>

</launch>
